NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

DB_FILE_NAME=file:./local.db



# API Credentials（API 凭证）

# IGDB API 客户端 ID，从 https://api.igdb.com 获取
# IGDB API Client ID, get from https://api.igdb.com
VITE_IGDB_API_ID=your_api_id_here
# IGDB API 客户端密钥
# IGDB API Client Secret
VITE_IGDB_API_KEY=your_client_secret_here

# STEAM API 密钥，从 https://steamcommunity.com/dev/apikey 获取
NEXT_PUBLIC_STEAM_API_KEY=xxx

# STEAM GRID API 密钥，从 https://www.steamgriddb.com/profile/preferences/api 获取
NEXT_PUBLIC_STEAMGRIDDB_API_KEY=xxx
NEXT_PUBLIC_STEAMGRIDDB_BASE_URL=https://www.steamgriddb.com/api/v2

# BANGUMI API 密钥，从 https://next.bgm.tv/demo/access-token 获取
# BANGUMI API Key, get from https://next.bgm.tv/demo/access-token
NEXT_PUBLIC_BANGUMI_API_KEY=xxx
NEXT_PUBLIC_BANGUMI_BASE_URL="https://api.bgm.tv"

VITE_AUTHENTIK_SERVER_URL=
VITE_AUTHENTIK_CLIENT_ID=
VITE_AUTHENTIK_CLIENT_SECRET=

VITE_COUCHDB_SERVER_URL=

# 第三方登录
# bangumi OAUTH 客户端 ID 和密钥，从 https://bgm.tv/settings/applications 获取
BANGUMI_OAUTH_CLIENT_ID=xxx
BANGUMI_OAUTH_CLIENT_SECRET=xxx

# vndb OAUTH 客户端 ID 和密钥，从 https://vndb.org/settings/api 获取
VNDB_OAUTH_TOKEN=xxx

