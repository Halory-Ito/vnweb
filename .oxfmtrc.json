{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [],
  "printWidth": 80,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "sortImports": {
    "order": "asc",
    "groups": [
      // 第一组：内置模块 和 第三方包 放在一起，中间不换行
      ["value-builtin", "value-external"],
      // 第二组：内部模块（通常配置了路径别名）、父级、同级、索引文件 放在一起，中间不换行
      ["value-internal", "value-parent", "value-sibling", "value-index"],
      // 分隔符：在第二组 和 下一组 之间 强制换行 (newlinesBetween: true)
      {
        "newlinesBetween": true
      },
      // 第三组：类型导入
      "type-import",
      // 第四组：其他未知导入
      "unknown"
    ]
  },
  "sortPackageJson": true,
  "sortTailwindcss": {
    "order": "asc"
  }
}
